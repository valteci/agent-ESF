APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Accepts TELEGRAM_BOT_TOKEN or TELEGRAM_API_KEY.
TELEGRAM_API_KEY=
TELEGRAM_TRANSPORT_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DOWNLOAD_MEDIA=true
TELEGRAM_ACK_ENABLED=false
TELEGRAM_ACK_TEMPLATE=Mensagem recebida e armazenada com sucesso.
TELEGRAM_POLLING_TIMEOUT_SECONDS=30
TELEGRAM_POLLING_SLEEP_SECONDS=1
TELEGRAM_CLEAR_WEBHOOK_ON_POLLING_START=true

STORAGE_ROOT=data
